{
  "name": "legal-advisor-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node server/index.js",
    "build": "vite build",
    "start": "node server/index.js",
    "stop": "npx --yes kill-port 3001 3002 5173",
    "production": "npm run stop && npm run build && node server/index.js --prod",
    "production:fresh": "npm run production",
    "media": "node scripts/fetch-media.mjs",
    "postinstall": "node scripts/fetch-media.mjs || true"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "multer": "^1.4.5-lts.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-router-dom": "^7.6.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.4.1",
    "vite": "^6.3.5"
  }
}
